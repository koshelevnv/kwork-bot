# Токен вашего Telegram бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=123:ABC

# ID администраторов бота через запятую (ваш Telegram user_id)
# Узнать свой ID можно у @userinfobot
ADMIN_IDS=123456789

# Начальные категории для мониторинга (ID из URL kwork.ru/projects?c=41)
# Можно менять через команды бота
KWORK_CATEGORIES=41,39

# Интервал проверки новых заказов в секундах
POLL_INTERVAL_SECONDS=30
